# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env (con secretos reales) a git.

# Cadena de conexión a Postgres. Formato:
# postgresql+psycopg2://<usuario>:<password>@<host>:<puerto>/<nombre_db>
# Si usas el docker-compose.yml incluido, estos valores ya calzan.
DATABASE_URL=postgresql+psycopg2://custofinder:custofinder@localhost:5432/custofinder

# OpenStreetMap (Nominatim + Overpass) no requiere API key ni tarjeta.
# Nominatim pide identificar tu app con un User-Agent que incluya un
# contacto real (política: https://operations.osmfoundation.org/policies/nominatim/).
OSM_CONTACT_EMAIL=tu_email@ejemplo.com

# Gemini (Google AI Studio, gratis, sin tarjeta). Una o más API keys
# separadas por coma, para rotar si una se queda sin cuota.
GEMINI_API_KEYS=""


# development | production
ENVIRONMENT=development