    StageUpdateRequest,
    LeadStageResponse,
    PipelineEventOut,
    PipelineHistoryResponse
)

from scrapers.competitor_scraper import find_competitors_with_website, analyze_competitor_sites

logging.basicConfig(level=logging.INFO)
